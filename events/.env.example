# Event service configuration
EVENT_SECRET=your_webhook_secret_here

# Discord bot configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here

# Server port
PORT=9000

# App name (used to construct project path: /root/${APP_NAME})
APP_NAME=terarush

# Allowed branches to trigger deploy (comma-separated, leave empty to allow all)
BRANCH=dev,staging,main
